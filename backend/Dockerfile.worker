# Build stage
FROM node:22-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

# Production worker stage
FROM node:22-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install --only=production

COPY --from=builder /app/dist ./dist
RUN mkdir -p /app/public/uploads/pdfs

ENV NODE_ENV=production

# Worker does not listen on HTTP. It only connects to Redis/Mongo and processes BullMQ queues.
CMD ["npm", "run", "start:worker:prod"]

