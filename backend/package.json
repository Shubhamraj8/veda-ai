{
  "name": "vedaai-backend",
  "version": "1.0.0",
  "description": "VedaAI Assessment Creator — Production Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc && tsc-alias",
    "worker": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only --exit-child src/worker.ts",
    "start": "node dist/server.js",
    "start:api:prod": "node dist/server.js",
    "start:worker:prod": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.10.0",
    "jsdom": "^29.0.0",
    "mongoose": "^9.3.1",
    "pdf-lib": "^1.17.1",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
